# --- Configuración web de Firebase (proyecto finance-app-abdf9) ---
# Los valores de cliente web de Firebase NO son secretos: son config pública
# que el SDK expone en el bundle. La autorización real la imponen las reglas
# de Firestore + el proveedor de Auth habilitado en consola.
#
# Cómo obtenerlos: Firebase Console > Project settings > General >
#   "Your apps" > (crea/selecciona una app Web </>) > "SDK setup and configuration".
#
# Si NO defines estas variables, src/lib/firebase.ts usa los valores por defecto
# (extraídos de app/google-services.json) salvo VITE_FIREBASE_APP_ID, que DEBE
# ser el appId de la app WEB (el de google-services.json es de Android y no sirve
# para el SDK JS).

VITE_FIREBASE_API_KEY=AIzaSyBPv01mYVEpURyvHilB982y7ILiFiF2zjw
VITE_FIREBASE_AUTH_DOMAIN=finance-app-abdf9.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=finance-app-abdf9
VITE_FIREBASE_STORAGE_BUCKET=finance-app-abdf9.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=318390629591

# OBLIGATORIO PARA PRODUCCIÓN: appId de la app WEB (formato 1:318390629591:web:XXXX).
# El appId de google-services.json es de Android (android:...) y NO funciona en el SDK JS.
# Rellena este al registrar la app web en la consola.
VITE_FIREBASE_APP_ID=REEMPLAZAR_CON_APP_ID_WEB
