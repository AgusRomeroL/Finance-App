rules_version = '2';

// Reglas de seguridad de Firestore — Fase B (multi-tenant).
//
// A partir de la Fase B la app admite VARIOS hogares y colaboradores:
//   - users/{uid}                         perfil + activeHouseholdId (solo el dueño del uid)
//   - users/{uid}/households/{hid}         espejo de mis membresías (solo el dueño del uid)
//   - households/{hid}                     doc del hogar (name, updatedAt)
//   - households/{hid}/roles/{uid}         { role: OWNER|COLLABORATOR, ... }
//   - households/{hid}/invites/{code}      { role, expiresAt, maxUses, uses, createdBy }
//   - households/{hid}/proposals/{id}      propuestas de colaboradores (propose-then-confirm)
//   - households/{hid}/{expenses|categories|members|wallets|quincenas|...}  datos del hogar
//
// El acceso al hogar se decide por la EXISTENCIA de households/{hid}/roles/{uid}:
// pertenecer = tener un doc de rol. OWNER lee/escribe todo; COLLABORATOR solo lee
// y puede crear propuestas.
//
// Antes del despliegue el usuario debe:
//   1) Habilitar Authentication (proveedores Anónimo + Google) en la consola Firebase.
//   2) Crear un OAuth 2.0 Web Client y ponerlo en AuthManager.WEB_CLIENT_ID + google-services.json.
//   3) firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // ¿El solicitante tiene un doc de rol en este hogar? (= pertenece)
    function isMember(hid) {
      return signedIn() &&
        exists(/databases/$(database)/documents/households/$(hid)/roles/$(request.auth.uid));
    }
    function roleIn(hid) {
      return get(/databases/$(database)/documents/households/$(hid)/roles/$(request.auth.uid)).data.role;
    }
    function isOwner(hid) {
      return isMember(hid) && roleIn(hid) == 'OWNER';
    }
    // Roles v2: PAYER ("Administrador") tiene los mismos privilegios de
    // escritura del ledger que el dueño; MEMBER/COLLABORATOR solo lee+propone.
    function isOwnerOrPayer(hid) {
      return isMember(hid) && roleIn(hid) in ['OWNER', 'PAYER'];
    }

    // ── users/{uid}/** — solo el propio uid ────────────────────────────────
    match /users/{uid} {
      allow read, write: if isSelf(uid);
      match /{document=**} {
        allow read, write: if isSelf(uid);
      }
    }

    // ── households/{hid} ────────────────────────────────────────────────────
    // La PROPIEDAD del hogar se ancla en el campo `createdBy` del doc del hogar:
    //   - Al FUNDAR un hogar (createHousehold) el cliente escribe createdBy = su uid.
    //   - Al RECLAMAR un hogar sin dueño (migración de la semilla, p. ej.
    //     default_household) el primer autenticado que estampa `createdBy` (cuando
    //     está vacío) queda como dueño; después ya no se puede cambiar.
    // Esto cierra el bypass anterior donde CUALQUIER usuario podía auto-asignarse
    // OWNER en CUALQUIER hogar (tomar control de hogares ajenos).
    match /households/{hid} {
      allow read: if isMember(hid);
      // Crear un hogar nuevo: debe quedar a nombre de quien lo crea.
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      // Actualizar/borrar: el dueño; o reclamar uno SIN dueño estampando createdBy.
      allow update: if isOwner(hid) || (
        signedIn() &&
        !("createdBy" in resource.data) &&
        request.resource.data.createdBy == request.auth.uid
      );
      allow delete: if isOwner(hid);

      // roles/{memberUid}: leer si eres miembro. Crear SOLO tu propio doc de rol,
      // y solo de forma legítima:
      //   - OWNER: únicamente si el hogar quedó a tu nombre (createdBy == tu uid).
      //   - No-OWNER: únicamente con un invite REAL de este hogar cuyo `role`
      //     coincide con el que te asignas (el cliente guarda `inviteCode`).
      // El dueño puede administrar cualquier rol.
      match /roles/{memberUid} {
        allow read: if isMember(hid);
        allow create: if isSelf(memberUid) && (
          (request.resource.data.role == 'OWNER' &&
            get(/databases/$(database)/documents/households/$(hid)).data.createdBy == request.auth.uid) ||
          (request.resource.data.role != 'OWNER' &&
            exists(/databases/$(database)/documents/households/$(hid)/invites/$(request.resource.data.inviteCode)) &&
            get(/databases/$(database)/documents/households/$(hid)/invites/$(request.resource.data.inviteCode)).data.role == request.resource.data.role &&
            // Roles v2: la nominación del invite es inmutable — quien canjea
            // queda vinculado al member que el dueño eligió, no a uno arbitrario.
            // .get(k, null) en ambos lados: invites legacy y clientes v1 no traen
            // la clave, y leer una clave ausente rompería la regla completa.
            request.resource.data.get('linkedMemberId', null) ==
              get(/databases/$(database)/documents/households/$(hid)/invites/$(request.resource.data.inviteCode)).data.get('linkedMemberId', null))
        );
        // Anti-degradación en servidor (bug del auto-canje): NADIE puede cambiar
        // su PROPIO role — ni siquiera el dueño (administra los ajenos).
        allow update: if isOwner(hid) &&
          (memberUid != request.auth.uid ||
            request.resource.data.role == resource.data.role);
        allow delete: if isOwner(hid);
      }

      // invites/{code}: cualquier autenticado puede LEER un invite por su código
      // (el código es el secreto). Crear/borrar solo el dueño. El canje solo puede
      // INCREMENTAR `uses` (no alterar rol/vigencia): update limitado a esa clave.
      match /invites/{code} {
        allow get: if signedIn();
        allow list: if isOwner(hid);
        allow create, delete: if isOwner(hid);
        allow update: if signedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses']);
      }

      // proposals/{id}: un COLABORADOR (o el dueño) crea propuestas; los miembros
      // las leen. El dueño puede actualizarlas/borrarlas (al confirmarlas).
      match /proposals/{id} {
        allow read: if isMember(hid);
        allow create: if isMember(hid);
        allow update, delete: if isOwnerOrPayer(hid);
      }

      // Datos del hogar (expenses, categories, members, wallets, quincenas,
      // wallet_transfer, income_source, savings_goal, loan, installment_plan y
      // subcolecciones como attributions): el dueño lee/escribe todo; el
      // colaborador SOLO lee (no puede tocar el ledger — para eso están las
      // propuestas).
      match /{collection}/{docId}/{sub=**} {
        allow read: if isMember(hid);
        allow write: if isOwnerOrPayer(hid);
      }
      match /{collection}/{docId} {
        allow read: if isMember(hid);
        allow write: if isOwnerOrPayer(hid);
      }
    }

    // ── invite_codes/{code} — índice global de códigos OPACOS ──────────────
    // Permite canjear una invitación con SOLO el código de 8 chars, sin exponer
    // el household id en lo que se comparte (antes el código era `{hid}.{code}`
    // y filtraba el id del hogar, p. ej. `default_household`). El doc mapea
    // code → { householdId, role, expiresAt, maxUses, uses, createdBy, updatedAt }.
    //   - get: cualquier autenticado (el código ES el secreto; no hay `list`,
    //     así que no se pueden enumerar códigos ajenos).
    //   - create: solo el OWNER del hogar apuntado por el doc NUEVO.
    //   - delete: solo el OWNER del hogar apuntado por el doc EXISTENTE
    //     (resource.data, no request.resource.data: en un delete no hay doc nuevo).
    //   - update: el canje solo puede tocar `uses` (incrementar el contador);
    //     rol/vigencia/hogar quedan inmutables para quien canjea.
    match /invite_codes/{code} {
      allow get: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.householdId);
      allow delete: if signedIn() && isOwner(resource.data.householdId);
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses']);
    }

    // Todo lo demás: cerrado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
