<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Red: solo la usa la importación de estados de cuenta (Fase C, paquete C1),
         que envía el TEXTO extraído localmente al LLM cloud de NVIDIA NIM. El PDF
         crudo nunca sale del dispositivo. El resto de la app es offline-first. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notificaciones y alarmas -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Dictado por voz en la barra de búsqueda (SpeechRecognizer) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Espejo opt-in a Google Calendar (Apéndice G.2, Fase 6). Solo se piden en
         runtime cuando el usuario activa el toggle; una vía, calendario dedicado. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- Ubicación del gasto (Apéndice G.4). Opt-in por nivel desde Perfil:
         "Solo al usar" pide FINE+COARSE en runtime; "Persistente" añade
         BACKGROUND_LOCATION (flujo aparte, Android 11+). Sin permiso = sin GPS. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <application
        android:name=".BudgetApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Presupuesto Familiar"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- Pantalla principal -->
        <!-- configChanges: al plegar/desplegar el Fold cambian screenSize/
             smallestScreenSize/screenLayout; sin esto la Activity se RECREA y
             todo `remember` no-saveable (captura a medias, mes del calendario,
             formularios) se pierde. Compose re-mide solo con onConfigurationChanged. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|density"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad de captura rápida (overlay transparente) -->
        <activity
            android:name=".ui.capture.QuickCaptureActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Captura en lenguaje natural por voz/texto (Apéndice G.3). Overlay
             transparente compartido por el botón de micrófono y el widget. -->
        <activity
            android:name=".ui.capture.VoiceCaptureActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Captura desde notificaciones bancarias (Feature D, §F.6).
             Requiere que el usuario conceda "Acceso a notificaciones" en Ajustes;
             además es opt-in vía el toggle de Perfil. -->
        <service
            android:name=".service.BankNotificationListenerService"
            android:exported="true"
            android:label="Captura de gastos"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Acciones [Registrar]/[Descartar] de la notificación propia de captura -->
        <receiver
            android:name=".data.capture.BankCaptureActionReceiver"
            android:exported="false" />

        <!-- Acciones [Confirmar]/[Posponer] del recordatorio de gastos PLANNED (Fase 3) -->
        <receiver
            android:name=".data.reminder.ReminderActionReceiver"
            android:exported="false" />

        <!-- Widget de captura rápida en pantalla de inicio (Jetpack Glance, §G.3) -->
        <receiver
            android:name=".widget.BudgetCaptureWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/budget_capture_widget_info" />
        </receiver>

        <!-- Servicio de sincronización Wear OS -->
        <service
            android:name=".service.BudgetWearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/budget"
                    android:scheme="wear" />
            </intent-filter>
        </service>

    </application>
</manifest>