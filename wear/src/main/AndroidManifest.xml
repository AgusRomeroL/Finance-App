<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Dictado por voz en el reloj (§G.3): el reloj capta voz, el teléfono parsea. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_wear_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BudgetWear">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!-- App companion (no standalone): depende del teléfono emparejado. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BudgetWear">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Escucha el push de saldo del teléfono (DataClient) → SharedPreferences. -->
        <service
            android:name=".data.MobileSyncListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/budget" />
            </intent-filter>
        </service>

        <!-- Actividad ligera de captura (monto+tipo+voz), lanzada desde el Tile B. -->
        <activity
            android:name=".presentation.CapturaActivity"
            android:exported="true"
            android:theme="@style/Theme.BudgetWear" />

        <!-- Tile A — Recomendados (ProtoLayout). -->
        <service
            android:name=".presentation.tile.SuggestionsTileService"
            android:exported="true"
            android:label="Recomendados"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

        <!-- Tile B — Captura (ProtoLayout). -->
        <service
            android:name=".presentation.tile.QuickEntryTileService"
            android:exported="true"
            android:label="Captura"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

        <!-- Tile — Disponible (arco héroe, ProtoLayout EdgeContentLayout). -->
        <service
            android:name=".presentation.tile.DisponibleTileService"
            android:exported="true"
            android:label="Disponible"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

        <!-- Tile — Próximos pagos (PLANNED, ProtoLayout). -->
        <service
            android:name=".presentation.tile.UpcomingPaymentsTileService"
            android:exported="true"
            android:label="Próximos pagos"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

        <!-- Tile — Gasto por miembro (mini-barras, ProtoLayout). -->
        <service
            android:name=".presentation.tile.MemberSpendTileService"
            android:exported="true"
            android:label="Gasto por miembro"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

        <!-- Tile — Pendientes por confirmar (ProtoLayout, abre el hub). -->
        <service
            android:name=".presentation.tile.PendingConfirmTileService"
            android:exported="true"
            android:label="Pendientes"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_wear_launcher" />
        </service>

    </application>
</manifest>
